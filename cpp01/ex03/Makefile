NAME        = anotherboringexercise

CXX         = c++
CXXFLAGS    = -Wall -Werror -Wextra -std=c++98

SRC         = HumanA.cpp \
			  HumanB.cpp \
			  Weapon.cpp \
			  main.cpp
OBJ         = $(SRC:.cpp=.o)

RESET       = \033[0m
PINK        = \033[1;35m
BLUE        = \033[1;36m
GREEN       = \033[1;32m
VIOLET		= \033[38;2;185;39;233m

TOTAL_SRCS := $(words $(SRC))

all: print $(NAME)

print:
	@echo "$(GREEN)"
	@echo " в Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җвў в ҙвЈ¶вЎҝвЈҝвЎҹвўҰ"
	@echo "в Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв ҖвЈҖвЈ в Өвў–вЎҜв ҙвЈҝв ҒвЈҝвЈҝвўё"
	@echo "в Җв Җв Җв Җavelandrв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв ҖвЈ вЎӨвЈ¶вў¶вЈҡвЈ©в Ҙв ӨвЈ–в Ӣв Җв ҖвЎҸв ів ¬в ҹвЎҮ"
	@echo "в Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв ҖвЈҖвЈӨвЈӨвЈӨвЈ„вЈҖв Җв Җвў вЈҝв —вЈһв үв үв Җв Җв Җв ҖвЈҮвЈ вўӨвЈ¶вЈ§вЎ„вЈҖвЈӨв ғ"
	@echo "в Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв ҖвЈ°в ӣв Ғв Җв Җв Җв Җв үвўівЎҖвЈ№в ҡвЈҫв ӣвЈҝвў»в үв үв үв үв үвўүвЎҸв Җв ҳвЈҝвўүвЎҮв Җ"
	@echo "в Җв Җв Җв Җв Җв Җв Җв Җв ҖвЈ°в һв Ғв Җ в Җв Җв Җв Җ в ҳвЈҜвўёвЎҝвЈҝвў—вЎӢвЈҝвўӨв ӨвЈӨв Өв Өв ¬в §в ҙв ҙв ӣв ӣв Ғв Җ"
	@echo "в Җв Җв Җв Җв Җв Җв Җв Җвў№вЎҹвЈҝвЎҝв ҝвЈ·вўҹвЈҝвЈҝвЎҝв ’в ҡвў»вЈ—вЎҹвЎҶвЈһвЈ§вЎҹвЈҝвў°в ғв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җ"
	@echo "в Җв Җв Җв Җв Җв Җв Җв Җв ҳвЎҹвўӢвЈҖвЈҖвЈҷвЎ»в ҹв Ӣв Җв Җв –вў»вЈҝв ЈвЈӯвЎҫвЈ®вў·вў»вЈ№в Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җ"
	@echo "в Җв Җв Җв Җв Җв Җв Җв Җв ҖвЈ§в Җв Җв Җв ёв Ғв Җв Җв Җв Җв ҖвЈёвЎјвўҖвЎҮв ҖвўёвЎүв үв Ғв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җ"
	@echo "в Җв Җв Җв Җв Җв Җв Җв Җв Җв №вЎ„в Җв Җв Җв Җв Җв Җв Җв ҖвЈ°в ҸвЎҮвЈёв Җв ҖвЎһв ғв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җ"
	@echo "в Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв ҷвўҰвЈ„в Җв Җв ҖвўҖвЈ вЎҫв ғв Җв ұвЈҮвЈҖвЎҙв ғв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җ"
	@echo "в Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җвўёв ҷв ӣв Ӣв үвўҝв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җ"
	@echo "в Җв Җв Җв Җв Җв Җв Җв Җв Җв Җвў вЎӨв ҫв Ӯв Җв ҖвўҖвЈёвЎҶв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җ"
	@echo "в Җ в Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв ҖвЈәвЈҒв Җв Җв Җв Җв Җв Җ в Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җ"
	@echo "$(RESET)"

$(NAME): $(OBJ)
	@echo ""
	@echo "$(BLUE)Linking objects...$(RESET)"
	@$(CXX) $(CXXFLAGS) $(OBJ) -o $(NAME)
	@echo "$(GREEN)Exercise $(NAME) compiled successfully!$(RESET)"

# mi barrita de carga
%.o: %.cpp
	@$(CXX) $(CXXFLAGS) -c $< -o $@
	@curr=$$(find . -type f -name "*.o" | wc -l); \
	percent=$$(( $$curr * 100 / $(TOTAL_SRCS) )); \
	bar_len=$$(( $$percent / 2 )); \
	bar_str=""; \
	i=0; \
	while [ $$i -lt $$bar_len ]; do bar_str="$${bar_str}в–“"; i=$$((i+1)); done; \
	spaces=""; \
	i=0; \
	rest=$$((50 - $$bar_len)); \
	while [ $$i -lt $$rest ]; do spaces="$${spaces}в–‘"; i=$$((i+1)); done; \
	printf "\r$(BLUE)Compiling: $(PINK)[$$bar_str$$spaces] $(PINK)$$percent%% $(RESET)"

clean:
	@rm -f $(OBJ)
	@echo "$(BLUE)Objects cleaned.$(RESET)"

fclean: clean
	@rm -f $(NAME)
	@echo "$(BLUE)Executable cleaned.$(RESET)"

re: fclean all

.PHONY: all clean fclean re
